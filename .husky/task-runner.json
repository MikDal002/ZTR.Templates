{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "dotnet format staged",
         "group": "pre-commit",
         "command": "dotnet",
         "args": [
            "format",
            "ZtrDotnetTemplates.sln",
            "--verbosity",
            "detailed",
            "--no-restore",
            "--include",
            "${staged}"
         ],
         "include": [
            "**/*.cs",
            "**/*.csproj",
            "**/*.sln",
            "**/*.targets"
         ]
      }
   ]
}
